# Supabase - Production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase - Testing (optional - for integration tests)
SUPABASE_TEST_URL=https://your-test-project.supabase.co
SUPABASE_TEST_SERVICE_ROLE_KEY=your-test-service-role-key-here
SUPABASE_TEST_ANON_KEY=your-test-anon-key-here

# Redis (optional - if using caching)
# REDIS_URL=redis://localhost:6379

# JWT 
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI 
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Telegram 
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Webhook mode 
TELEGRAM_WEBHOOK_URL=https://your-service-xxxxx.run.app
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string-here
# TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook  # default, rarely needs changing

# Environment
ENVIRONMENT=development
# LOG_LEVEL=DEBUG